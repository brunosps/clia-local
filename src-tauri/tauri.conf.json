{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clia.local",
  "version": "0.1.0",
  "identifier": "dev.clia.local",
  "build": {
    "beforeDevCommand": "corepack pnpm exec vite --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "corepack pnpm build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "clia.local",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["binaries/rtk/*"],
    "category": "DeveloperTool",
    "shortDescription": "clia.local — fully local agent development environment",
    "longDescription": "A fully local desktop agent development environment. No cloud."
  }
}
